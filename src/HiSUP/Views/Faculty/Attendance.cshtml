@model List<HiSUP.Models.Section>
@{ ViewData["Title"] = "Mark Attendance"; }
<h4 class="fw-bold mb-4"><i class="bi bi-calendar-check text-primary"></i> Mark Attendance</h4>
<div class="card p-3">
    <table class="table table-hover">
        <thead class="table-light">
            <tr><th>Section</th><th>Course</th><th>Semester</th><th>Seats</th></tr>
        </thead>
        <tbody>
            @foreach (var s in Model)
            {
                <tr>
                    <td>@s.SectionID</td>
                    <td>@s.Course?.CourseName</td>
                    <td>@s.SemesterLabel</td>
                    <td>@s.SeatsAvailable / @s.SeatsTotal</td>
                </tr>
            }
        </tbody>
    </table>
</div>
