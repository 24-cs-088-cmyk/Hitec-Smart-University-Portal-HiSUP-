@model List<HiSUP.Models.Enrollment>
@{ ViewData["Title"] = "Grades"; }
<h4 class="fw-bold mb-4"><i class="bi bi-award text-primary"></i> Grade Entry</h4>
<div class="card p-3">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr><th>Student</th><th>Course</th><th>Marks</th><th>Grade</th></tr>
        </thead>
        <tbody>
            @foreach (var e in Model)
            {
                <tr>
                    <td>@e.Student?.FirstName @e.Student?.LastName</td>
                    <td>@e.Section?.Course?.CourseName</td>
                    <td>@(e.Grade?.MarksObtained.ToString("F1") ?? "—")</td>
                    <td>@(e.Grade?.LetterGrade ?? "—")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
