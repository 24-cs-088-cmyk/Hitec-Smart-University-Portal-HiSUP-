@model HiSUP.Controllers.RegisterViewModel
@{ ViewData["Title"] = "Register"; Layout = null; }

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>HiSUP — Register</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css"/>
    <style>
        body { background: linear-gradient(135deg, #1e3a5f 0%, #0d6efd 100%); min-height: 100vh; }
        .card { border-radius: 16px; box-shadow: 0 20px 60px rgba(0,0,0,.3); }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center py-4">
<div class="card p-4" style="width:440px">
    <div class="text-center mb-4">
        <i class="bi bi-building" style="font-size:2.5rem;color:#0d6efd"></i>
        <h4 class="fw-bold mt-2">Create Account</h4>
    </div>

    <form asp-action="Register" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Full Name</label>
            <input asp-for="FullName" class="form-control" placeholder="Ali Raza"/>
            <span asp-validation-for="FullName" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Email</label>
            <input asp-for="Email" class="form-control" placeholder="ali@student.hitecuni.edu.pk"/>
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Password</label>
            <input asp-for="Password" class="form-control" placeholder="Min 8 characters"/>
            <span asp-validation-for="Password" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Role</label>
            <select asp-for="Role" class="form-select">
                <option value="Student">Student</option>
                <option value="Faculty">Faculty</option>
                <option value="Finance">Finance</option>
                <option value="Admin">Admin</option>
            </select>
        </div>

        <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
            <i class="bi bi-person-plus"></i> Register
        </button>
    </form>

    <hr/>
    <div class="text-center small">
        Already have an account? <a asp-action="Login">Sign in</a>
    </div>
</div>
</body>
</html>
