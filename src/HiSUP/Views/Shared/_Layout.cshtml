<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - HiSUP</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css"/>
    <style>
        body { background: #f8f9fa; }
        .navbar-brand { font-weight: 700; letter-spacing: 1px; }
        .sidebar { min-height: calc(100vh - 56px); background: #212529; }
        .sidebar .nav-link { color: #adb5bd; padding: .6rem 1rem; border-radius: 6px; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { background: #0d6efd; color: #fff; }
        .sidebar .nav-link i { margin-right: 8px; }
        .card { border: none; box-shadow: 0 2px 8px rgba(0,0,0,.08); border-radius: 12px; }
        .stat-card { border-left: 4px solid; }
    </style>
</head>
<body>
<nav class="navbar navbar-dark bg-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">
            <i class="bi bi-building"></i> HiSUP
        </a>
        @if (User.Identity!.IsAuthenticated)
        {
            <div class="d-flex align-items-center gap-3">
                <span class="text-light small">
                    <i class="bi bi-person-circle"></i> @User.Identity.Name
                </span>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button class="btn btn-outline-light btn-sm">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </button>
                </form>
            </div>
        }
    </div>
</nav>

<div class="container-fluid">
    <div class="row">
        @if (User.Identity!.IsAuthenticated)
        {
            <div class="col-md-2 sidebar py-3">
                <nav class="nav flex-column gap-1">
                    @if (User.IsInRole("Student"))
                    {
                        <a class="nav-link" asp-controller="Student" asp-action="Index">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                        <a class="nav-link" asp-controller="Student" asp-action="Courses">
                            <i class="bi bi-book"></i> Courses
                        </a>
                        <a class="nav-link" asp-controller="Student" asp-action="Fees">
                            <i class="bi bi-cash"></i> Fee History
                        </a>
                        <a class="nav-link" asp-controller="Student" asp-action="Transcript">
                            <i class="bi bi-file-earmark-text"></i> Transcript
                        </a>
                        <a class="nav-link" asp-controller="Library" asp-action="Index">
                            <i class="bi bi-journal-bookmarks"></i> Library
                        </a>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <a class="nav-link" asp-controller="Admin" asp-action="Index">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                        <a class="nav-link" asp-controller="Admin" asp-action="Students">
                            <i class="bi bi-people"></i> Students
                        </a>
                        <a class="nav-link" asp-controller="Admin" asp-action="AuditLog">
                            <i class="bi bi-shield-check"></i> Audit Log
                        </a>
                    }
                    @if (User.IsInRole("Faculty"))
                    {
                        <a class="nav-link" asp-controller="Faculty" asp-action="Index">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                        <a class="nav-link" asp-controller="Faculty" asp-action="Attendance">
                            <i class="bi bi-calendar-check"></i> Attendance
                        </a>
                        <a class="nav-link" asp-controller="Faculty" asp-action="Grades">
                            <i class="bi bi-award"></i> Grades
                        </a>
                    }
                    @if (User.IsInRole("Finance"))
                    {
                        <a class="nav-link" asp-controller="Finance" asp-action="Index">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                        <a class="nav-link" asp-controller="Finance" asp-action="Defaulters">
                            <i class="bi bi-exclamation-triangle"></i> Defaulters
                        </a>
                    }
                </nav>
            </div>
        }
        <main class="col py-4">
            @RenderBody()
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
