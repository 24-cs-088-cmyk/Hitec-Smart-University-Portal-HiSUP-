@{ ViewData["Title"] = "Finance Dashboard"; }
<h4 class="fw-bold mb-4"><i class="bi bi-cash-stack text-primary"></i> Finance Dashboard</h4>
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card p-3 stat-card" style="border-color:#198754">
            <div class="text-muted small">Total Collected</div>
            <div class="fs-3 fw-bold">Rs. @ViewBag.TotalCollected?.ToString("N0")</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-3 stat-card" style="border-color:#0d6efd">
            <div class="text-muted small">Total Payments</div>
            <div class="fs-3 fw-bold">@ViewBag.TotalPayments</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-3 stat-card" style="border-color:#dc3545">
            <div class="text-muted small">Pending/Partial</div>
            <div class="fs-3 fw-bold">@ViewBag.PendingCount</div>
        </div>
    </div>
</div>
<a asp-action="Defaulters" class="btn btn-danger">
    <i class="bi bi-exclamation-triangle"></i> View Defaulters
</a>
