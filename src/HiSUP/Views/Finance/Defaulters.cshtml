@model List<HiSUP.Models.FeePayment>
@{ ViewData["Title"] = "Fee Defaulters"; }
<h4 class="fw-bold mb-4"><i class="bi bi-exclamation-triangle text-danger"></i> Fee Defaulters</h4>
<div class="card p-3">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr><th>Student</th><th>Amount Due</th><th>Paid</th><th>Status</th><th>Date</th></tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.Student?.FirstName @p.Student?.LastName</td>
                    <td>Rs. @p.FeeStructure?.Amount.ToString("N0")</td>
                    <td>Rs. @p.AmountPaid.ToString("N0")</td>
                    <td><span class="badge bg-warning text-dark">@p.Status</span></td>
                    <td>@p.PaymentDate.ToString("dd/MM/yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
