@{ ViewData["Title"] = "Student Dashboard"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">
            <i class="bi bi-speedometer2 text-primary"></i>
            Welcome, @(ViewBag.User?.FullName ?? User.Identity?.Name ?? "Student")!
        </h4>
        @if (ViewBag.Student != null)
        {
            <small class="text-muted">@ViewBag.Student?.Department?.DeptName • Semester @ViewBag.Student?.CurrentSemester</small>
        }
        else
        {
            <small class="text-warning"><i class="bi bi-exclamation-triangle"></i> Profile Not Linked</small>
        }
    </div>
    @if (ViewBag.Student != null)
    {
        <span class="badge bg-primary fs-6">CGPA: @ViewBag.Student?.CGPA.ToString("F2")</span>
    }
</div>

@if (ViewBag.Student == null)
{
    <div class="alert alert-warning shadow-sm">
        <h5 class="alert-heading"><i class="bi bi-info-circle"></i> Complete Your Profile</h5>
        <p>You have successfully registered an account, but your profile has not been linked to an official academic student record yet.</p>
        <hr>
        <p class="mb-0">Please contact the administration or academic office to link your account to your student ID to view your courses, transcript, and fee history.</p>
    </div>
}
else
{

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card stat-card p-3" style="border-color:#0d6efd">
            <div class="d-flex justify-content-between">
                <div>
                    <div class="text-muted small">Active Courses</div>
                    <div class="fs-4 fw-bold">@(((List<HiSUP.Models.Enrollment>)ViewBag.Enrollments)?.Count ?? 0)</div>
                </div>
                <i class="bi bi-book fs-2 text-primary opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card p-3" style="border-color:#198754">
            <div class="d-flex justify-content-between">
                <div>
                    <div class="text-muted small">CGPA</div>
                    <div class="fs-4 fw-bold">@ViewBag.Student?.CGPA.ToString("F2")</div>
                </div>
                <i class="bi bi-graph-up fs-2 text-success opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card p-3" style="border-color:#ffc107">
            <div class="d-flex justify-content-between">
                <div>
                    <div class="text-muted small">Semester</div>
                    <div class="fs-4 fw-bold">@ViewBag.Student?.CurrentSemester</div>
                </div>
                <i class="bi bi-calendar fs-2 text-warning opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card p-3" style="border-color:#dc3545">
            <div class="d-flex justify-content-between">
                <div>
                    <div class="text-muted small">Program</div>
                    <div class="fs-5 fw-bold">@ViewBag.Student?.Program?.Degree</div>
                </div>
                <i class="bi bi-mortarboard fs-2 text-danger opacity-50"></i>
            </div>
        </div>
    </div>
</div>

<!-- Current Enrollments -->
<div class="card p-3">
    <h6 class="fw-bold mb-3"><i class="bi bi-list-check text-primary"></i> Current Enrollments</h6>
    @if (ViewBag.Enrollments != null && ((List<HiSUP.Models.Enrollment>)ViewBag.Enrollments).Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Course</th>
                        <th>Faculty</th>
                        <th>Room</th>
                        <th>Credits</th>
                        <th>Grade</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in (List<HiSUP.Models.Enrollment>)ViewBag.Enrollments)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@e.Section?.Course?.CourseName</div>
                                <small class="text-muted">@e.Section?.Course?.CourseCode</small>
                            </td>
                            <td>@e.Section?.Faculty?.FirstName @e.Section?.Faculty?.LastName</td>
                            <td>@e.Section?.Room</td>
                            <td>@e.Section?.Course?.CreditHours</td>
                            <td>
                                @if (e.Grade != null)
                                {
                                    <span class="badge bg-success">@e.Grade.LetterGrade (@e.Grade.MarksObtained)</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Pending</span>
                                }
                            </td>
                            <td><span class="badge bg-primary">@e.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center text-muted py-4">
            <i class="bi bi-inbox fs-1"></i>
            <p>No active enrollments. <a asp-action="Courses">Browse courses</a></p>
        </div>
    }
</div>
}
