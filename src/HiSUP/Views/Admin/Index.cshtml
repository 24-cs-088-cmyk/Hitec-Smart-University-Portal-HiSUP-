@{ ViewData["Title"] = "Admin Dashboard"; }
<h4 class="fw-bold mb-4"><i class="bi bi-speedometer2 text-primary"></i> Admin Dashboard</h4>
<div class="row g-3">
    <div class="col-md-3">
        <div class="card p-3 stat-card" style="border-color:#0d6efd">
            <div class="text-muted small">Total Students</div>
            <div class="fs-3 fw-bold">@ViewBag.TotalStudents</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3 stat-card" style="border-color:#198754">
            <div class="text-muted small">Total Faculty</div>
            <div class="fs-3 fw-bold">@ViewBag.TotalFaculty</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3 stat-card" style="border-color:#ffc107">
            <div class="text-muted small">Total Courses</div>
            <div class="fs-3 fw-bold">@ViewBag.TotalCourses</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3 stat-card" style="border-color:#dc3545">
            <div class="text-muted small">Fee Collected</div>
            <div class="fs-3 fw-bold">Rs. @ViewBag.TotalPayments?.ToString("N0")</div>
        </div>
    </div>
</div>
<div class="row g-3 mt-2">
    <div class="col-md-4">
        <a asp-action="Students" class="card p-3 text-decoration-none text-dark d-block">
            <i class="bi bi-people fs-2 text-primary"></i>
            <div class="fw-semibold mt-2">Manage Students</div>
            <small class="text-muted">View and manage all students</small>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-action="AuditLog" class="card p-3 text-decoration-none text-dark d-block">
            <i class="bi bi-shield-check fs-2 text-success"></i>
            <div class="fw-semibold mt-2">Audit Log</div>
            <small class="text-muted">View all database changes</small>
        </a>
    </div>
</div>
